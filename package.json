{
  "name": "phishing-url-detection",
  "version": "1.0.0",
  "description": "Phishing URL detection via string pattern matching, comparing KMP, Rabin-Karp and Aho-Corasick.",
  "type": "module",
  "scripts": {
    "server": "nodemon --watch server server/server.js",
    "client": "npm --prefix client run dev",
    "dev": "concurrently -n server,client -c blue,green \"npm run server\" \"npm run client\"",
    "start": "node server/server.js",
    "seed": "node server/data/seed.js",
    "benchmark": "node server/benchmark/runBenchmark.js",
    "test": "node --test \"server/algorithms/**/*.test.js\""
  },
  "keywords": [
    "phishing",
    "kmp",
    "rabin-karp",
    "aho-corasick",
    "string-matching",
    "mern"
  ],
  "license": "MIT",
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "mongoose": "^8.5.1"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "nodemon": "^3.1.4"
  }
}
